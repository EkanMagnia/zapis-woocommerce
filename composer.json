{
    "name": "ekanmagnia/zapis-woocommerce",
    "description": "Conectează WooCommerce cu Zapis pentru semnături electronice de contract post-checkout.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Zapis\\WooCommerce\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zapis\\WooCommerce\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
