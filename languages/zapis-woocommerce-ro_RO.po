msgstr "Titlu"

msgid "Apare în partea de sus a box-ului. Default:"
msgstr "Apare în partea de sus a box-ului. Default:"

msgid "Text body"
msgstr "Text body"

msgid "Formatare permisă: bold, italic, link-uri, liste. Lasă gol pentru textul implicit."
msgstr "Formatare permisă: bold, italic, link-uri, liste. Lasă gol pentru textul implicit."

msgid "Text buton"
msgstr "Text buton"

msgid "Default:"
msgstr "Default:"

msgid "Culoare gradient — start"
msgstr "Culoare gradient — start"

msgid "Culoarea din stânga-sus a gradientului. Folosită și pentru textul butonului. Default:"
msgstr "Culoarea din stânga-sus a gradientului. Folosită și pentru textul butonului. Default:"

